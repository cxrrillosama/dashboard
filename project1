    function initPresetConfigurations() {
      const stored = localStorage.getItem('GE_CUSTOM_PRESETS');
      if (stored) { try { customPresets = JSON.parse(stored); } catch(e) { customPresets = []; } }
    }

    function initializeSheetPresets(dataArray) {
      sheetPresets = Array.isArray(dataArray) ? dataArray : []; populatePresetSelectors();
    }

    function initializeWorkNotesPresets(dataArray) {
      workNotesPresets = Array.isArray(dataArray) ? dataArray : []; populatePresetSelectors();
    }

    function initializeThreadRequestsPresets(dataArray) {
      threadrequestsPresets = Array.isArray(dataArray) ? dataArray : []; populatePresetSelectors();
    }

    function populatePresetSelectors() {
      const systemSelector = document.getElementById('system-preset-selector');
      const workSelector = document.getElementById('work-notes-preset-selector');
      const ticketSelector = document.getElementById('ticket-summary-preset-selector');
      const customSelector = document.getElementById('custom-preset-selector');
      const spawnSelector = document.getElementById('default-spawn-selector');
      
      if (!systemSelector || !workSelector || !ticketSelector || !customSelector || !spawnSelector) return;
      const currentSpawnRuleValue = localStorage.getItem('GE_DEFAULT_SPAWN') || 'blank';
      
      systemSelector.innerHTML = '<option value="" disabled selected>-- Select Layout --</option>';
      workSelector.innerHTML = '<option value="" disabled selected>-- Select Layout --</option>';
      ticketSelector.innerHTML = '<option value="" disabled selected>-- Select Layout --</option>';
      customSelector.innerHTML = '<option value="" disabled selected>-- Select Preset --</option>';
      spawnSelector.innerHTML = '<option value="blank">Blank Slate (Empty Note)</option>';
      
      if (sheetPresets.length) {
        sheetPresets.forEach((p, idx) => {
          systemSelector.innerHTML += `<option value="${idx}">${p.name}</option>`;
          spawnSelector.innerHTML += `<option value="sheet-${idx}">[FD] ${p.name}</option>`;
        });
      } else { systemSelector.innerHTML = '<option value="" disabled selected>No Layouts</option>'; }

      if (workNotesPresets.length) {
        workNotesPresets.forEach((p, idx) => {
          workSelector.innerHTML += `<option value="${idx}">${p.name}</option>`;
          spawnSelector.innerHTML += `<option value="work-${idx}">[Work] ${p.name}</option>`;
        });
      } else { workSelector.innerHTML = '<option value="" disabled selected>No Layouts</option>'; }

      if (threadrequestsPresets.length) {
        threadrequestsPresets.forEach((p, idx) => {
          ticketSelector.innerHTML += `<option value="${idx}">${p.name}</option>`;
          spawnSelector.innerHTML += `<option value="ticket-${idx}">[Ticket] ${p.name}</option>`;
        });
      } else { ticketSelector.innerHTML = '<option value="" disabled selected>No Layouts</option>'; }

      if (customPresets.length) {
        customPresets.forEach((p, idx) => {
          customSelector.innerHTML += `<option value="${idx}">${p.name}</option>`;
          spawnSelector.innerHTML += `<option value="custom-${idx}">[Custom] ${p.name}</option>`;
        });
      } else { customSelector.innerHTML = '<option value="" disabled selected>No Custom Presets</option>'; }
      
      spawnSelector.value = currentSpawnRuleValue;
      renderPresetManagerList();
    }

    function getDefaultSpawnText() {
      const spawnVal = localStorage.getItem('GE_DEFAULT_SPAWN') || 'blank';
      if (spawnVal === 'blank') return "";
      const parts = spawnVal.split('-');
      const origin = parts[0]; const targetIdx = parseInt(parts[1], 10);
      if (origin === 'sheet' && sheetPresets[targetIdx]) return sheetPresets[targetIdx].text;
      if (origin === 'work' && workNotesPresets[targetIdx]) return workNotesPresets[targetIdx].text;
      if (origin === 'ticket' && threadrequestsPresets[targetIdx]) return threadrequestsPresets[targetIdx].text;
      if (origin === 'custom' && customPresets[targetIdx]) return customPresets[targetIdx].text;
      return ""; 
    }

    function renderPresetManagerList() {
      const listContainer = document.getElementById('custom-presets-list-container');
      if (!listContainer) return;
