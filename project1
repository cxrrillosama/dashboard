   function renderKB(dataArray) {
  document.getElementById('kb-loader').classList.add('hidden');
  const list = document.getElementById('kb-list');
  if (!list) return;
  list.classList.remove('hidden');
  
  if (!dataArray || dataArray.length === 0 || dataArray[0].startsWith("Error")) {
    list.innerHTML = `<li class="kb-item"><div class="kb-text">${(dataArray && dataArray[0]) || "No updates found."}</div></li>`;
    return;
  }
  
  // Custom helper to parse HTML formatting for URLs and markdown bold ** tokens
  const processRichFeedContent = (text) => {
    if (!text) return "";
    
    // 1. Convert HTML reserved symbols to avoid breaking layout elements
    let cleanOutput = text
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;");
      
    // 2. Parse markdown double asterisks (**text**) into explicit bold elements with forced priority styling
    cleanOutput = cleanOutput.replace(/\*\*(.*?)\*\*/g, '<strong style="font-weight: 700 !important; color: var(--text-white);">$1</strong>');
    
    // 3. Scan for raw web addresses and transform into clickable links
    const urlRegex = /(https?:\/\/[^\s]+)/gi;
    return cleanOutput.replace(urlRegex, (url) => {
      return `<a href="${url}" target="_blank" style="color: var(--neon-orange); text-decoration: underline; font-weight: bold;">${url}</a>`;
    });
  };

  // Maps the formatted HTML entries cleanly into the view list items
  list.innerHTML = dataArray.map(item => `<li class="kb-item"><div class="kb-text">${processRichFeedContent(item)}</div></li>`).join('');
}

