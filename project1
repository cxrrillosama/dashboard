    function forceSaveCurrentNote() {
      const title = document.getElementById('active-title').value.trim();
      const content = document.getElementById('active-editor').innerHTML;
      const secondaryContent = document.getElementById('secondary-editor').innerHTML;
      if (!title) return;

      const timestamp = new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
      let existingIndex = cachedNotes.findIndex(n => n.title === activeNoteOriginalTitle);
      
      if (existingIndex > -1) {
        cachedNotes[existingIndex].title = title; cachedNotes[existingIndex].content = content;
        cachedNotes[existingIndex].secondaryContent = secondaryContent; cachedNotes[existingIndex].timestamp = timestamp;
      } else {
        existingIndex = cachedNotes.findIndex(n => n.title === title);
        if (existingIndex > -1) {
          cachedNotes[existingIndex].content = content; cachedNotes[existingIndex].secondaryContent = secondaryContent;
          cachedNotes[existingIndex].timestamp = timestamp;
        } else { cachedNotes.unshift({ title, content, secondaryContent, timestamp }); }
      }
      activeNoteOriginalTitle = title; saveNotesToCloud(); renderNotesHistory();
    }

