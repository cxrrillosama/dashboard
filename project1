    function initThemePreference() {
      const savedTheme = localStorage.getItem('GE_UI_THEME') || 'dark';
      document.documentElement.setAttribute('data-theme', savedTheme);
      document.getElementById('theme-selector').value = savedTheme;
    }

    document.getElementById('theme-selector').onchange = function switchDisplayTheme() {
      const selectedTheme = document.getElementById('theme-selector').value;
      document.documentElement.setAttribute('data-theme', selectedTheme);
      localStorage.setItem('GE_UI_THEME', selectedTheme);
    }

    function initIncrementalSequenceTracker() {
      const storedIndex = localStorage.getItem('GE_NEXT_NOTE_INDEX');
      if (storedIndex) nextNoteIndex = parseInt(storedIndex, 10);
    }

    function initSignatureModalState() {
      const dropdown = document.getElementById('sig-phone-dropdown');
      if (dropdown && dropdown.options.length > 0 && dropdown.selectedIndex !== -1) {
        const selectedUser = dropdown.options[dropdown.selectedIndex].text.split(':')[0].trim();
        baseSignatureState = localStorage.getItem('GE_SIG_' + selectedUser) || "Type your email signature here...";
      } else {
        baseSignatureState = localStorage.getItem('GE_POPUP_SIGNATURE_CONTENT') || "Type your email signature here...";
      }
      document.getElementById('sig-modal-textbox').value = baseSignatureState;
    }

    function openSignatureModal() {
      document.getElementById('modal-backdrop-node').classList.add('active');
      document.getElementById('signature-modal-window').classList.add('active');
      if (phonebookRegistry.length > 0) {
        const dropdown = document.getElementById('sig-phone-dropdown');
        if (dropdown.selectedIndex === -1) dropdown.selectedIndex = 0;
        onSignatureDropdownChange();
      } else {
        document.getElementById('sig-modal-textbox').value = baseSignatureState;
      }
    }

    function closeSignatureModal() {
      document.getElementById('modal-backdrop-node').classList.remove('active');
      document.getElementById('signature-modal-window').classList.remove('active');
    }

    function initializePhonebookDropdown(contactsArray) {
      const dropdown = document.getElementById('sig-phone-dropdown');
      if (!contactsArray || contactsArray.length === 0) {
        dropdown.innerHTML = '<option value="">No Numbers Available</option>';
        return;
      }
      phonebookRegistry = contactsArray;
      dropdown.innerHTML = ''; 
      contactsArray.forEach(item => {
        dropdown.innerHTML += `<option value="${item.phone}">${item.name}: ${item.phone}</option>`;
      });
      initSignatureModalState();
    }

    function appendPhoneFromDropdown() {
      const dropdown = document.getElementById('sig-phone-dropdown');
      const textbox = document.getElementById('sig-modal-textbox');
      let workingText = baseSignatureState;
      if (dropdown && dropdown.value) { workingText += "\nPhone: " + dropdown.value; }
      textbox.value = workingText;
    }

    function copySignatureModalText(event) {
      const textContent = document.getElementById('sig-modal-textbox').value;
      const targetBtn = event ? event.currentTarget : document.querySelector('.sig-btn-copy');
      navigator.clipboard.writeText(textContent).then(() => {
        if (targetBtn) {
          const originalText = targetBtn.innerText; targetBtn.innerText = "Copied!"; 
          setTimeout(() => { targetBtn.innerText = originalText; }, 1200);
        }
      });
    }

    function saveSignatureModalText() {
      const textboxValue = document.getElementById('sig-modal-textbox').value;
      const dropdown = document.getElementById('sig-phone-dropdown');
      if (!dropdown || dropdown.options.length === 0 || dropdown.selectedIndex === -1) {
        localStorage.setItem('GE_POPUP_SIGNATURE_CONTENT', textboxValue);
        alert("Global fallback signature saved!"); closeSignatureModal(); return;
      }
      const selectedUser = dropdown.options[dropdown.selectedIndex].text.split(':')[0].trim();
      const phoneIndex = textboxValue.lastIndexOf("\nPhone:");
      const signatureToSave = (phoneIndex !== -1) ? textboxValue.substring(0, phoneIndex) : textboxValue;
      baseSignatureState = signatureToSave;
      localStorage.setItem('GE_SIG_' + selectedUser, signatureToSave);
      alert("Signature saved for " + selectedUser); closeSignatureModal();
    }

    function onSignatureDropdownChange() {
      const dropdown = document.getElementById('sig-phone-dropdown');
      if (!dropdown || dropdown.selectedIndex === -1) return;
      const selectedUser = dropdown.options[dropdown.selectedIndex].text.split(':')[0].trim();
      baseSignatureState = localStorage.getItem('GE_SIG_' + selectedUser) || "Type your email signature here..."; 
      appendPhoneFromDropdown(); 
    }

    function saveDefaultSpawn() {
      const selector = document.getElementById('default-spawn-selector');
      if (!selector) return;
      localStorage.setItem('GE_DEFAULT_SPAWN', selector.value);
      const status = document.getElementById('save-status');
