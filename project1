<!DOCTYPE html>
<html>
<head>
  <base target="_top">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght=400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet">
  <style>
    :root {
      --bg-main: #121214;
      --bg-deep-gray: #1a1a1e;
      --input-bg: #26262b;
      --border-dark: #2d2d34;
      --text-white: #f5f5f7;
      --text-muted: #a1a1aa;
      --neon-orange: #f8901f;
      --modal-border: #3f3f46;
      --transition-smooth: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
      --sidebar-width: 320px;
      --notes-pane-height: 280px;
      --top-editor-height: 50%;
      --footer-height: 350px;
    }
    
    [data-theme="light"] {
      --bg-main: #f4f4f5;
      --bg-deep-gray: #ffffff;
      --input-bg: #e4e4e7;
      --border-dark: #d4d4d8;
      --text-white: #18181b;
      --text-muted: #71717a;
      --neon-orange: #e07810;
      --modal-border: #e4e4e7;
    }

    body { margin: 0; padding: 0; font-family: 'Inter', sans-serif; background-color: var(--bg-main); color: var(--text-white); height: 100vh; overflow: hidden; }
    
    .dashboard-container { display: flex; width: 100vw; height: 100vh; position: relative; }
    
    .sidebar { width: var(--sidebar-width); background: var(--bg-deep-gray); border-right: 1px solid var(--border-dark); display: flex; flex-direction: column; height: 100%; transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1); position: relative; flex-shrink: 0; }
    .dashboard-container.sidebar-collapsed .sidebar { width: 50px !important; }
    .dashboard-container.sidebar-collapsed #sidebar-resizer-handle { display: none; }
    
    .sidebar-header { padding: 16px; border-bottom: 1px solid var(--border-dark); display: flex; align-items: center; justify-content: space-between; overflow: hidden; white-space: nowrap; }
    .brand { font-weight: 700; font-size: 16px; color: var(--neon-orange); display: flex; align-items: center; gap: 8px; cursor: pointer; user-select: none; }
    .brand span { font-size: 22px; }
    
    .sidebar-pane { display: flex; flex-direction: column; overflow: hidden; }
    #notes-pane { height: var(--notes-pane-height); min-height: 80px; }
    #kb-pane { flex: 1; min-height: 120px; border-top: 1px solid var(--border-dark); }
    
    .dashboard-container.sidebar-collapsed .sidebar-pane,
    .dashboard-container.sidebar-collapsed .sidebar-search,
    .dashboard-container.sidebar-collapsed #bulk-mgmt-subbar { display: none !important; }
    
    .sidebar-section-title-row { padding: 12px 16px 6px 16px; display: flex; justify-content: space-between; align-items: center; }
    .sidebar-section-title { margin: 0; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); }
    
    .sidebar-search { margin: 0 16px 8px 16px; padding: 6px 10px; background: var(--input-bg); border: 1px solid var(--border-dark); border-radius: 6px; color: var(--text-white); font-size: 12px; outline: none; }
    
    .scroll-list { list-style: none; margin: 0; padding: 0 8px; overflow-y: auto; flex: 1; }
    .list-item { padding: 8px 10px; border-radius: 6px; cursor: pointer; display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px; transition: var(--transition-smooth); gap: 8px; }
    .list-item:hover { background: var(--input-bg); }
    .item-info { display: flex; flex-direction: column; min-width: 0; flex: 1; }
    .item-title { font-size: 13px; font-weight: 500; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: var(--text-white); }
    .item-sub { font-size: 11px; color: var(--text-muted); margin-top: 2px; }
    
    .kb-item { padding: 10px 12px; border-bottom: 1px solid var(--border-dark); font-size: 12.5px; line-height: 1.5; color: var(--text-white); }
    .kb-text {
  font-size: 13px;
  line-height: 1.5;
  white-space: pre-wrap;
  word-break: break-word;
  font-weight: 400; /* This forces EVERYTHING inside to have a normal weight */
}
    /* NEW: Preset Quick Response Footer Styles */
.preset-qr-bottom-bar {
  height: 120px;
  background: var(--bg-deep-gray);
  border-top: 1px solid var(--border-dark);
  display: flex;
  align-items: center;
  padding: 10px 14px;
  gap: 12px;
  overflow-x: auto;
  flex-shrink: 0;
}

/* Ensure the cards in the footer sit side-by-side */
.preset-qr-bottom-bar .qr-deck-card {
  width: 250px;
  min-width: 250px;
  flex-shrink: 0;
  height: 100%;
}
    .delete-note-icon { color: var(--text-muted); cursor: pointer; padding: 2px; border-radius: 4px; transition: var(--transition-smooth); }
    .delete-note-icon:hover { color: #ff4444; background: rgba(255,68,68,0.1); }
    
    .resizer-v { width: 4px; cursor: col-resize; background: transparent; transition: background 0.2s; flex-shrink: 0; z-index: 10; }
    .resizer-v:hover, .resizer-v.active-dragging { background: var(--neon-orange); }
    .resizer-h { height: 4px; cursor: row-resize; background: transparent; transition: background 0.2s; z-index: 10; }
    .resizer-h:hover, .resizer-h.active-dragging { background: var(--neon-orange); }
    
    .workspace-center { flex: 1; display: flex; flex-direction: row; height: 100%; min-width: 0; background-color: var(--bg-main); }
    .workspace-main-view { flex: 1; display: flex; flex-direction: column; overflow: hidden; height: 100%; }
    
    .toolbar { height: 48px; background: var(--bg-deep-gray); border-bottom: 1px solid var(--border-dark); display: flex; align-items: center; justify-content: space-between; padding: 0 16px; flex-shrink: 0; }
    .toolbar-group { display: flex; align-items: center; gap: 12px; }
    .toolbar-icon { color: var(--text-muted); cursor: pointer; font-size: 20px !important; padding: 6px; border-radius: 6px; transition: var(--transition-smooth); }
    .toolbar-icon:hover { color: var(--neon-orange); background: var(--input-bg); }
    .toolbar-divider { width: 1px; height: 20px; background: var(--border-dark); margin: 0 4px; }
    
    .btn { background: var(--neon-orange); color: #121214; border: none; padding: 8px 16px; font-size: 13px; font-weight: 600; border-radius: 6px; cursor: pointer; transition: var(--transition-smooth); }
    .btn:hover { opacity: 0.9; }
    .btn-outline { background: transparent; border: 1px solid var(--border-dark); color: var(--text-white); }
    .btn-outline:hover { background: var(--input-bg); border-color: var(--text-muted); }
    .btn-action-text { background: transparent; border: none; color: var(--text-white); display: flex; align-items: center; gap: 6px; font-size: 13px; font-weight: 500; cursor: pointer; padding: 6px 10px; border-radius: 6px; transition: var(--transition-smooth); }
    .btn-action-text:hover { background: var(--input-bg); color: var(--neon-orange); }
    .btn-action-text span { font-size: 18px; }
    
    .select-theme { background: var(--input-bg); border: 1px solid var(--border-dark); color: var(--text-white); border-radius: 6px; outline: none; cursor: pointer; }
    
    .preset-bar { background: var(--bg-deep-gray); border-bottom: 1px solid var(--border-dark); padding: 8px 16px; display: flex; flex-direction: column; gap: 8px; flex-shrink: 0; }
    .preset-row { display: flex; align-items: center; gap: 14px; overflow-x: auto; white-space: nowrap; }
    .preset-bar-header-label { margin: 0; font-size: 11px; font-weight: 700; text-transform: uppercase; color: var(--neon-orange); letter-spacing: 0.05em; }
    .preset-group-unit { display: flex; align-items: center; gap: 6px; }
    .preset-inner-label { font-size: 12px; color: var(--text-muted); font-weight: 500; }
    .select-preset { background: var(--input-bg); border: 1px solid var(--border-dark); color: var(--text-white); padding: 4px 8px; font-size: 12px; border-radius: 6px; outline: none; max-width: 150px; }
    .push-right { margin-left: auto; }
    
    .editor-stack-container { flex: 1; display: flex; flex-direction: column; overflow: hidden; padding: 12px; gap: 8px; }
    .card { background: var(--bg-deep-gray); border: 1px solid var(--border-dark); border-radius: 8px; display: flex; flex-direction: column; overflow: hidden; }
    .canvas-card { position: relative; }
    #top-canvas-node { height: var(--top-editor-height); min-height: 100px; }
    #bottom-canvas-node { flex: 1; min-height: 100px; }
    
    .canvas-meta { padding: 8px 12px; background: rgba(0,0,0,0.15); border-bottom: 1px solid var(--border-dark); display: flex; justify-content: space-between; align-items: center; }
    .btn-copy { padding: 4px 10px; font-size: 11px; font-weight: 600; text-transform: none; }
    
    .note-title-input { background: transparent; border: none; border-bottom: 1px solid var(--border-dark); color: var(--text-white); font-size: 15px; font-weight: 700; padding: 10px 14px; outline: none; width: 100%; box-sizing: border-box; }
    .editor-container { flex: 1; position: relative; padding: 4px; overflow: hidden; }
    
    .editor-area { width: 100%; height: 100%; background: transparent; border: none; outline: none; color: var(--text-white); font-family: inherit; font-size: 13.5px; line-height: 1.6; padding: 8px; box-sizing: border-box; overflow-y: auto; white-space: pre-wrap; word-break: break-word; }
    .editor-area img { max-width: 100%; max-height: 280px; border-radius: 6px; margin: 6px 0; display: block; border: 1px solid var(--border-dark); }
    .editor-area:empty::before { content: attr(placeholder); color: var(--text-muted); pointer-events: none; display: block; }
    
    .quick-resp-footer { width: var(--footer-height); background: var(--bg-deep-gray); border-left: 1px solid var(--border-dark); display: flex; flex-direction: column; overflow: hidden; flex-shrink: 0; height: 100%; }
    .qr-footer-nav { width: 100%; border-bottom: 1px solid var(--border-dark); display: flex; flex-direction: column; padding: 12px; box-sizing: border-box; gap: 4px; overflow-y: auto; max-height: 280px; flex-shrink: 0; }
    .qr-footer-nav-title { font-size: 10px; font-weight: 700; text-transform: uppercase; color: var(--text-muted); padding: 4px; letter-spacing: 0.05em; display: flex; justify-content: space-between; align-items: center; }
    .qr-footer-btn { display: flex; align-items: center; gap: 8px; padding: 6px 8px; border-radius: 6px; font-size: 12px; color: var(--text-muted); cursor: pointer; transition: var(--transition-smooth); }
    .qr-footer-btn:hover { background: var(--input-bg); color: var(--text-white); }
    .qr-footer-btn.active { background: var(--input-bg); color: var(--neon-orange); font-weight: 600; }
    .qr-footer-btn span { font-size: 16px; }
    .folder-delete-icon { font-size: 14px !important; color: var(--text-muted); margin-left: auto; visibility: hidden; }
    .qr-footer-btn:hover .folder-delete-icon { visibility: visible; }
    .folder-delete-icon:hover { color: #ff4444 !important; }
    
    .quick-response-cards-node { flex: 1; padding: 12px; overflow-y: auto; display: flex; flex-direction: column; gap: 8px; align-items: stretch; }
    .qr-deck-card { width: 100%; background: var(--input-bg); border: 1px solid var(--border-dark); border-radius: 12px; padding: 10px 14px; box-sizing: border-box; display: flex; flex-direction: column; transition: var(--transition-smooth); gap: 10px; }
    .qr-deck-card:hover { border-color: var(--neon-orange); background: rgba(255, 255, 255, 0.01); }
    
    .qr-deck-left-group { display: flex; align-items: flex-start; gap: 8px; flex: 1; min-width: 0; }
    .btn-copy-macro-inline { color: var(--text-muted); cursor: pointer; font-size: 18px !important; padding: 4px; border-radius: 6px; transition: var(--transition-smooth); flex-shrink: 0; margin-top: -2px; }
    .btn-copy-macro-inline:hover { color: var(--neon-orange); background: rgba(248, 144, 31, 0.1); }
    
    .qr-deck-body { font-size: 12.5px; line-height: 1.5; color: var(--text-white); white-space: pre-wrap; word-break: break-word; flex: 1; }
    .qr-deck-actions { display: flex; align-items: center; justify-content: flex-end; gap: 12px; flex-shrink: 0; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 6px; }
    
    .qr-action-icon-btn { font-size: 18px !important; color: var(--text-muted); cursor: pointer; padding: 4px; border-radius: 6px; transition: var(--transition-smooth); }
    .qr-action-icon-btn:hover { color: var(--neon-orange); background: rgba(248, 144, 31, 0.1); }
    .qr-action-icon-btn.active { color: var(--neon-orange); }
    .qr-action-icon-btn.delete-icon:hover { color: #ff4444; background: rgba(255, 68, 68, 0.1); }
    
    .modal-overlay { position: fixed; top:0; left:0; width:100vw; height:100vh; background: rgba(0,0,0,0.5); display:none; z-index:100; opacity:0; transition: opacity 0.2s ease; }
    .modal-overlay.active { display: block; opacity: 1; }
    
    .sig-modal-window, .preset-manager-panel, .custom-modal-window, #vault-panel { position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%) scale(0.95); background: var(--bg-deep-gray); border: 1px solid var(--modal-border); border-radius: 12px; padding: 20px; width: 420px; box-sizing: border-box; z-index: 105; display: none; opacity: 0; transition: transform 0.2s ease, opacity 0.2s ease; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.5); }
    .sig-modal-window.active, .preset-manager-panel.active, .custom-modal-window.active, #vault-panel.active { display: flex; flex-direction: column; transform: translate(-50%, -50%) scale(1); opacity: 1; }
    
    .sig-modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
    .sig-modal-header h3 { margin: 0; font-size: 16px; font-weight: 700; color: var(--text-white); }
    .sig-modal-close { color: var(--text-muted); cursor: pointer; font-size: 20px !important; }
    .sig-modal-close:hover { color: var(--text-white); }
    
    .sig-textarea-wrapper { flex: 1; margin-bottom: 12px; }
    .sig-textarea { width: 100%; height: 120px; background: var(--input-bg); border: 1px solid var(--border-dark); border-radius: 8px; color: var(--text-white); padding: 10px; font-size: 13px; font-family: inherit; resize: none; outline: none; box-sizing: border-box; }
    .sig-control-row { margin-bottom: 14px; }
    .sig-dropdown { background: var(--input-bg); border: 1px solid var(--border-dark); color: var(--text-white); padding: 8px 10px; border-radius: 8px; outline: none; font-size: 13px; box-sizing: border-box; }
    .sig-action-container { display: flex; justify-content: flex-end; gap: 10px; }
    .sig-btn-save { background: var(--neon-orange); color: #121214; border: none; padding: 8px 16px; font-size: 13px; font-weight: 600; border-radius: 8px; cursor: pointer; }
    .sig-btn-copy { background: transparent; border: 1px solid var(--border-dark); color: var(--text-white); padding: 8px 16px; font-size: 13px; font-weight: 600; border-radius: 8px; cursor: pointer; }
    
    .panel-item-row { display: flex; justify-content: space-between; align-items: center; background: var(--input-bg); padding: 8px 12px; border-radius: 6px; margin-bottom: 6px; font-size: 13px; }
    .vault-scroll-area { overflow-y: auto; max-height: 320px; padding-right: 2px; }
    .vault-card { background: var(--input-bg); border: 1px solid var(--border-dark); padding: 12px; border-radius: 8px; margin-bottom: 10px; }
    .vault-card h4 { margin: 0 0 8px 0; font-size: 14px; color: var(--neon-orange); }
    .vault-detail { display: flex; justify-content: space-between; align-items: center; font-size: 12.5px; color: var(--text-white); margin-bottom: 4px; }
    
    .btn-sm { padding: 8px 14px; font-size: 12px; border-radius: 8px; width: auto; text-transform: none; font-weight: 600; }
    
    input[type="text"], input[type="password"], textarea.preset-textarea { width: 100%; padding: 10px 14px; background-color: var(--input-bg); border: 1px solid var(--border-dark); color: var(--text-white); border-radius: 8px; outline: none; margin-bottom: 12px; box-sizing: border-box; font-size: 13.5px; font-family: inherit; transition: var(--transition-smooth); }
    input[type="text"]:focus, input[type="password"]:focus, textarea.preset-textarea:focus { border-color: var(--neon-orange); box-shadow: 0 0 0 3px rgba(248, 144, 31, 0.15); }
    textarea.preset-textarea { height: 90px; resize: none; margin-bottom: 8px; line-height: 1.5; }
    
    .form-group { margin-bottom: 4px; }
    .form-row { display: flex; gap: 10px; }
    .form-row > div { flex: 1; }
    .loader { color: var(--text-muted); font-size: 12px; padding: 12px 0; font-style: italic; }
    .hidden { display: none !important; }
    hr { border: 0; border-top: 1px solid var(--border-dark); margin: 16px 0; }
    .modal-title-black { color: #111111 !important; margin: 0; font-size: 18px; font-weight: 700; letter-spacing: -0.02em; }
    [data-theme="dark"] .modal-title-black { color: var(--text-white) !important; }

    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--border-dark); border-radius: 10px; }
    ::-webkit-scrollbar-thumb:hover { background: var(--text-muted); }

    .collapsed-indicator { display: none; color: var(--text-muted); cursor: pointer; padding: 14px 16px; text-align: center; }
    .dashboard-container.sidebar-collapsed .collapsed-indicator { display: block; }
    .dashboard-container.sidebar-collapsed .brand { display: none; }
  </style>
</head>
<body>

  <div class="dashboard-container" id="app-root-container">
    <div class="sidebar">
      <div class="sidebar-header">
        <div class="brand" onclick="toggleSidebarCollapse()" title="Click to collapse sidebar"><span class="material-icons-round">all_inclusive</span>GE Dashboard</div>
      </div>
      
      <div class="collapsed-indicator" onclick="toggleSidebarCollapse()" title="Click to expand sidebar">
        <span class="material-icons-round">menu</span>
      </div>
      
      <div class="sidebar-pane" id="notes-pane">
        <div class="sidebar-section-title-row">
          <p class="sidebar-section-title">Saved Notes Log</p>
          <span class="material-icons-round toolbar-icon" id="bulk-toggle-icon" title="Toggle Multiple Selection Mode" onclick="toggleBulkDeleteMode()" style="font-size: 20px !important; color: var(--text-muted); padding: 4px;">rule</span>
        </div>
        
        <div id="bulk-mgmt-subbar" class="hidden" style="padding: 0 20px 8px 20px; display: flex; justify-content: space-between; align-items: center; gap: 10px;">
          <span id="bulk-count-label" style="font-size: 11px; color: var(--neon-orange); font-weight: bold;">0 Chosen</span>
          <button class="btn btn-sm btn-danger" onclick="executeBulkDelete()" style="padding: 4px 10px; font-size: 11px;">Delete Selected</button>
        </div>

        <input type="text" id="notes-search-bar" class="sidebar-search" placeholder="Search notes history..." onkeyup="filterNotes()">
        <div id="notes-loader" class="loader" style="padding-left:20px;">Loading data stream...</div>
        <ul id="notes-history-list" class="scroll-list hidden"></ul>
      </div>

      <div id="pane-resizer-handle" class="resizer-h"></div>

      <div class="sidebar-pane" id="kb-pane">
        <div class="sidebar-section-title-row">
          <p class="sidebar-section-title">GE Updates Feed</p>
          <span id="sync-timestamp-tag" style="font-size: 10px; color: var(--text-muted); font-style: italic;"></span>
        </div>
        <div id="kb-loader" class="loader" style="padding-left:20px;">Synchronizing updates...</div>
        <ul id="kb-list" class="scroll-list hidden"></ul>
      </div>
    </div>

    <div id="sidebar-resizer-handle" class="resizer-v"></div>

    <div class="workspace-center">
      <div class="workspace-main-view">
        <div class="toolbar">
  <div class="toolbar-group">
    <span class="material-icons-round toolbar-icon" title="Toggle Sidebar Expand/Collapse" onclick="toggleSidebarCollapse()">menu</span>
    <span class="material-icons-round toolbar-icon" title="Open Secure Vault" onclick="openVaultModal()">lock</span>
    <span class="material-icons-round toolbar-icon" id="sig-panel-trigger" title="My Signature Builder" onclick="openSignatureModal()">assignment_ind</span>
    <span class="material-icons-round toolbar-icon" title="Manage Custom Presets" onclick="openPresetManagerModal()">settings</span>
    <span class="material-icons-round toolbar-icon" title="Log Call Trending" onclick="openCallTrendingModal()">analytics</span>
    
    <div class="toolbar-divider"></div>
    
    <button class="btn-action-text" onclick="copyCurrentDate(this)" title="Copy Current Date to Clipboard">
      <span class="material-icons-round">calendar_today</span>
      <span id="current-date-display">Loading Date...</span>
    </button>
    <div class="toolbar-divider"></div>
   
  </div>
  <div class="toolbar-group">
          
            <span class="material-icons-round" style="font-size: 20px; color: var(--text-muted);">palette</span>
            <select id="theme-selector" class="select-theme" onchange="switchDisplayTheme()" style="padding: 4px 28px 4px 10px; font-size: 12px; width: auto;">
              <option value="dark">Dark UI</option>
              <option value="light">Light UI</option>
            </select>
          </div>
        </div>

        <div class="preset-bar">
          <div class="preset-row">
            <h3 class="preset-bar-header-label">Templates</h3>
            
            <div class="preset-group-unit">
              <span class="preset-inner-label">FD Notes</span>
              <select id="system-preset-selector" class="select-preset" onchange="injectSystemPreset()">
                <option value="" disabled selected>-- Select Layout --</option>
              </select>
            </div>

            <div class="preset-group-unit">
              <span class="preset-inner-label">Categories</span>
              <select id="work-notes-preset-selector" class="select-preset" onchange="injectWorkNotesPreset()">
                <option value="" disabled selected>-- Select Layout --</option>
              </select>
            </div>

            <div class="preset-group-unit">
              <span class="preset-inner-label">Thread Requests</span>
              <select id="ticket-summary-preset-selector" class="select-preset" onchange="injectThreadRequestsPreset()">
                <option value="" disabled selected>-- Select Layout --</option>
              </select>
            </div>
          </div>

          <div class="preset-row">
            <div class="preset-group-unit">
              <span class="preset-inner-label">Custom:</span>
              <select id="custom-preset-selector" class="select-preset" onchange="injectCustomPreset()">
                <option value="" disabled selected>-- Select Preset --</option>
              </select>
            </div>
            
            <div class="preset-group-unit push-right">
              <span class="preset-inner-label">Default</span>
              <select id="default-spawn-selector" class="select-preset" onchange="saveDefaultSpawn()">
                <option value="blank">Blank Slate (Empty Note)</option>
              </select>
            </div>
          </div>
        </div>

        <div class="editor-stack-container">
          <div class="card canvas-card" id="top-canvas-node">
           <div class="canvas-meta">
  <div style="display: flex; align-items: center; gap: 10px;">
    <button class="btn-outline btn-copy" onclick="copyNoteToClipboard('active-editor', event)" style="display:flex; align-items:center; gap:6px; border-radius: 8px;">
