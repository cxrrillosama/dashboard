    function executeBulkDelete() {
      if (!selectedNoteTitles.length) return alert("Select notes to execute bulk deletion.");
      if (!confirm(`Permanently delete all ${selectedNoteTitles.length} chosen notes simultaneously?`)) return;
      const currentWorkspaceTitle = document.getElementById('active-title').value;
      cachedNotes = cachedNotes.filter(n => !selectedNoteTitles.includes(n.title)); saveNotesToCloud();
      const wasActiveNoteDeleted = selectedNoteTitles.includes(currentWorkspaceTitle) || selectedNoteTitles.includes(activeNoteOriginalTitle);
