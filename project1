        submitBtn.disabled = false;
        if (response && response.success) {
          alert("Call trend metrics logged successfully!");
          closeCallTrendingModal();
        } else {
          alert("Log failure: " + (response.error || "Unknown issue."));
        }
      }).logCallTrendingData(payload);
    }

    function initClipboardPasteInterceptors() {
      const editors = ['active-editor', 'secondary-editor'];
      editors.forEach(id => {
        const field = document.getElementById(id);
        if (!field) return;
        
        field.addEventListener('paste', function(event) {
          const clipboardItems = (event.clipboardData || event.originalEvent.clipboardData).items;
          for (let i = 0; i < clipboardItems.length; i++) {
            const item = clipboardItems[i];
            if (item.type.indexOf('image') === 0) {
              event.preventDefault(); 
              const imageFile = item.getAsFile();
              const reader = new FileReader();
              reader.onload = function(e) {
                const base64DataUrl = e.target.result;
                const imgElement = document.createElement('img');
                imgElement.src = base64DataUrl;
                const selection = window.getSelection();
                if (selection.rangeCount > 0) {
                  const range = selection.getRangeAt(0);
                  range.deleteContents();
                  range.insertNode(imgElement);
                  range.setStartAfter(imgElement);
                  range.setEndAfter(imgElement);
                  selection.removeAllRanges();
                  selection.addRange(range);
                } else {
                  field.appendChild(imgElement);
                }
              };
              reader.readAsDataURL(imageFile);
              break; 
            }
          }
        });
      });
    }

    function fetchSystemPresetsAndNotes() {
      google.script.run.withSuccessHandler(function(fdData) {
        initializeSheetPresets(fdData);
        google.script.run.withSuccessHandler(function(workData) {
          initializeWorkNotesPresets(workData);
          google.script.run.withSuccessHandler(function(ticketData) {
            initializeThreadRequestsPresets(ticketData);
            google.script.run.withSuccessHandler(initializeNotes).getUserNotes();
          }).getThreadRequestsPresets();
        }).getWorkNotesPresets();
      }).getSpreadsheetPresets();
    }

    function fetchUpdatesFeedData() {
      google.script.run.withSuccessHandler(function(dataArray) {
        renderKB(dataArray);
        lastUpdateTimestamp = new Date();
        updateRelativeTimeLabel();
      }).getSharedTemplates();
    }

    function updateRelativeTimeLabel() {
      const label = document.getElementById('sync-timestamp-tag');
      if (!label || !lastUpdateTimestamp) return;
      const diffMins = Math.floor((new Date() - lastUpdateTimestamp) / 60000);
      label.innerText = diffMins < 1 ? "Just now" : `${diffMins}m ago`;
    }

    function toggleSidebarCollapse() {
      const container = document.getElementById('app-root-container');
      if (container) container.classList.toggle('sidebar-collapsed');
