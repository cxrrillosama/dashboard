    function copyNoteToClipboard(targetEditorId, event) {
      const editor = document.getElementById(targetEditorId);
      const textContent = editor.innerText || editor.textContent;
      const htmlContent = editor.innerHTML;
      const targetBtn = event ? event.currentTarget : null;
      
      const blobHtml = new Blob([htmlContent], { type: 'text/html' });
      const blobText = new Blob([textContent], { type: 'text/plain' });
      
      const data = [new ClipboardItem({
        'text/html': blobHtml,
        'text/plain': blobText
      })];
      
      navigator.clipboard.write(data).then(() => {
        if (targetBtn) {
          const originalText = targetBtn.innerHTML; 
          targetBtn.innerHTML = `<span class="material-icons-round" style="font-size:14px;">check</span> Copied!`; 
          setTimeout(() => { targetBtn.innerHTML = originalText; }, 1500);
        }
      }).catch(err => {
        navigator.clipboard.writeText(textContent).then(() => {
          if (targetBtn) {
            const originalText = targetBtn.innerHTML; 
            targetBtn.innerHTML = `<span class="material-icons-round" style="font-size:14px;">check</span> Copied!`; 
            setTimeout(() => { targetBtn.innerHTML = originalText; }, 1500);
          }
        });
      });
    }

