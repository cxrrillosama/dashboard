        const isFooterCategory = (qr.category === "Ticket Summary" || qr.category === "Work Notes");

        if (isFooterCategory && footerContainer) {
            footerContainer.insertAdjacentHTML('beforeend', cardHTML);
        } else if (sidebarContainer) {
            sidebarContainer.insertAdjacentHTML('beforeend', cardHTML);
        }
    });
}

    function setQuickResponseCategory(categoryKey) {
      activeQRFilterCategory = categoryKey;
      document.querySelectorAll('.qr-footer-nav .qr-footer-btn').forEach(btn => btn.classList.remove('active'));
      let targetId = (categoryKey === 'all' || categoryKey === 'favs') ? `qr-filter-${categoryKey}` : `qr-filter-${categoryKey.toLowerCase().replace(/\s+/g, '-')}`;
      const activeBtn = document.getElementById(targetId);
      if (activeBtn) activeBtn.classList.add('active');
      renderQuickResponsesDashboard();
    }

    function executeQuickResponseCopy(itemId, event) {
      const match = quickResponsesList.find(i => i.id === itemId);
      if (!match) return;
      const btnNode = event.currentTarget;
      navigator.clipboard.writeText(match.text).then(() => {
        const orig = btnNode.innerText; btnNode.innerText = 'check'; btnNode.style.color = 'var(--neon-orange)';
        setTimeout(() => { btnNode.innerText = orig; btnNode.style.color = ''; }, 1200);
      });
    }

    function toggleQuickResponseFav(itemId, event) {
      event.stopPropagation();
      const match = quickResponsesList.find(i => i.id === itemId);
      if (match) { match.favorite = !match.favorite; saveQuickResponsesToCloud(); renderQuickResponsesDashboard(); }
    }

    function openAddResponseModal() {
      document.getElementById('modal-backdrop-node').classList.add('active');
      document.getElementById('add-response-modal-window').classList.add('active');
    }

    function closeAddResponseModal() {
      document.getElementById('modal-backdrop-node').classList.remove('active');
      document.getElementById('add-response-modal-window').classList.remove('active');
      document.getElementById('new-qr-text').value = '';
    }

    function submitNewQuickResponse() {
      const textVal = document.getElementById('new-qr-text').value.trim();
      const catVal = document.getElementById('new-qr-category').value;
      if (!textVal) return alert("Response content field is required.");
      quickResponsesList.push({ id: "qr_" + Date.now(), text: textVal, category: catVal, favorite: false });
      saveQuickResponsesToCloud(); closeAddResponseModal(); setQuickResponseCategory(catVal);
    }

    function deleteQuickResponse(itemId, event) {
      event.stopPropagation();
      if (!confirm("Permanently remove this quick response card?")) return;
      quickResponsesList = quickResponsesList.filter(i => i.id !== itemId);
      saveQuickResponsesToCloud(); renderQuickResponsesDashboard();
    }

    function saveQuickResponsesToCloud() { google.script.run.saveQuickResponses(JSON.stringify(quickResponsesList)); }

    function openVaultModal() {
      document.getElementById('modal-backdrop-node').classList.add('active');
      document.getElementById('vault-panel').classList.add('active');
      checkVaultSetupState();
      if (sessionStorage.getItem('vaultSessionActive') === 'true') transitionToActiveVault();
    }

    function closeVaultModal() {
      document.getElementById('modal-backdrop-node').classList.remove('active');
      document.getElementById('vault-panel').classList.remove('active');
      document.getElementById('active-vault').classList.add('hidden');
      document.getElementById('unlock-gate').classList.remove('hidden');
      globalVaultData = {};
    }

    const SHIFT_OFFSET = 7;
    function encryptPayload(str) { return btoa(encodeURIComponent(str)).split('').map(c => String.fromCharCode(c.charCodeAt(0) + SHIFT_OFFSET)).join(''); }
    function decryptPayload(str) { const unshifted = str.split('').map(c => String.fromCharCode(c.charCodeAt(0) - SHIFT_OFFSET)).join(''); return decodeURIComponent(atob(unshifted)); }

    function checkVaultSetupState() {
      const storedMaster = localStorage.getItem('vaultMasterPassword');
      const inst = document.getElementById('gate-instructions');
      const input = document.getElementById('master-password');
      const btn = document.getElementById('btn-gate-action');
      const resumeBtn = document.getElementById('btn-session-reopen');
      if (resumeBtn) { resumeBtn.classList.toggle('hidden', sessionStorage.getItem('vaultSessionActive') !== 'true'); }
      if (!storedMaster) {
        inst.innerHTML = "<strong style='color: var(--neon-orange);'>SETUP REQUIRED:</strong> Configure Vault Access Protocol.";
        input.placeholder = "Create Master Password"; btn.innerText = "Initialize Vault"; if(resumeBtn) resumeBtn.classList.add('hidden');
      } else { inst.innerText = "Encrypted local utility."; input.placeholder = "Enter Master Password"; btn.innerText = "Unlock Vault"; }
    }
function renderQuickResponses(filterCategory = 'all') {
    // 1. Grab both containers
    const rightColumnNode = document.getElementById('quick-response-cards-node');
    const bottomFooterNode = document.getElementById('preset-qr-footer');

    // 2. Clear out old rendering
    rightColumnNode.innerHTML = '';
    bottomFooterNode.innerHTML = '';

    // 3. Loop through your global quickResponsesList
    quickResponsesList.forEach(qr => {
        
        // Optional: Apply your existing filter logic here
        if (filterCategory !== 'all' && qr.category !== filterCategory) return;

        // 4. Build your card HTML (Use your existing card HTML structure here)
        const cardHTML = `
            <div class="qr-deck-card">
                <div class="qr-deck-body">${qr.text}</div>
            </div>
        `;

        // 5. Route the card based on whether it is custom or a preset
        // (Adjust the condition below based on how your data structure flags custom vs presets)
        if (qr.isCustom === true || qr.folder === 'Custom') {
            rightColumnNode.insertAdjacentHTML('beforeend', cardHTML);
        } else {
            bottomFooterNode.insertAdjacentHTML('beforeend', cardHTML);
        }
    });
}
    function handleGateAction() {
      const inputPass = document.getElementById('master-password').value;
      const storedMaster = localStorage.getItem('vaultMasterPassword');
      if (!inputPass) return alert("Credentials mandatory.");
      if (!storedMaster) {
        localStorage.setItem('vaultMasterPassword', inputPass); sessionStorage.setItem('vaultSessionActive', 'true'); transitionToActiveVault();
      } else {
        if (inputPass !== storedMaster) { document.getElementById('master-password').value = ''; return alert("Authentication Mismatch."); }
        sessionStorage.setItem('vaultSessionActive', 'true'); transitionToActiveVault();
      }
    }

    function reopenFromSession() { transitionToActiveVault(); }

    function transitionToActiveVault() {
      document.getElementById('unlock-gate').classList.add('hidden');
      document.getElementById('active-vault').classList.remove('hidden');
      document.getElementById('master-password').value = '';
      document.getElementById('vault-items-loader').classList.remove('hidden');
      google.script.run.withSuccessHandler(scrambled => {
        document.getElementById('vault-items-loader').classList.add('hidden');
        try { globalVaultData = scrambled ? JSON.parse(decryptPayload(scrambled)) : {}; } catch(e) { globalVaultData = {}; }
        renderVaultItems();
      }).loadVaultData();
    }

    function saveToVault() {
      const toolName = document.getElementById('tool-name').value.trim();
      const username = document.getElementById('tool-user').value.trim();
      const password = document.getElementById('tool-pass').value;
      if (!toolName || !username || !password) return alert("Attributes partial.");
      globalVaultData[toolName] = { username, password };
      google.script.run.withSuccessHandler(() => {
        document.getElementById('tool-name').value = ''; document.getElementById('tool-user').value = ''; document.getElementById('tool-pass').value = '';
        renderVaultItems();
      }).saveVaultData(encryptPayload(JSON.stringify(globalVaultData)));
    }

    function renderVaultItems() {
      const container = document.getElementById('vault-items');
      if (!container) return; container.innerHTML = ''; const keys = Object.keys(globalVaultData).sort();
      if (!keys.length) { container.innerHTML = '<p style="color:var(--text-muted);font-size:12px;text-align:center;">Vault Void</p>'; return; }
      keys.forEach(tool => {
        const creds = globalVaultData[tool];
        const card = document.createElement('div'); card.className = 'vault-card'; card.setAttribute('data-tool', tool.toLowerCase());
        card.innerHTML = `
          <h4>${tool}</h4>
          <div class="vault-detail"><span>U: ${creds.username}</span><button class="btn btn-outline btn-copy" onclick="copyToClipboard('${creds.username.replace(/'/g, "\\'")}', event)">Copy</button></div>
          <div class="vault-detail"><span>P: ••••••••</span><button class="btn btn-outline btn-copy" onclick="copyToClipboard('${creds.password.replace(/'/g, "\\'")}', event)">Copy</button></div>
        `;
        container.appendChild(card);
      });
    }

    function filterTools() {
      const query = document.getElementById('search-bar').value.toLowerCase();
      document.querySelectorAll('.vault-card').forEach(c => c.style.display = c.getAttribute('data-tool').includes(query) ? 'block' : 'none');
    }

    function emergencyReset(e) {
      if (e && e.preventDefault) e.preventDefault();
      if (confirm("CRITICAL WARNING: This completely deletes your cloud Notes AND Vault data permanently. Continue?")) {
        google.script.run.withSuccessHandler(() => {
          globalVaultData = {}; cachedNotes = []; nextNoteIndex = 100; quickResponsesList = []; appFoldersList = ["Welcome", "Wait", "End"];
          localStorage.removeItem('vaultMasterPassword'); sessionStorage.removeItem('vaultSessionActive');
          closeAllModals(); renderNotesHistory(); createNewNote(true); initFoldersMatrixAndLoadMacros(); alert("Purge Complete.");
        }).clearAllUserData();
      }
    }
    
function copyToClipboard(textToCopy, event) {
  const targetBtn = event ? event.currentTarget : null;
  
  navigator.clipboard.writeText(textToCopy).then(() => {
    if (targetBtn) {
      const originalText = targetBtn.innerText;
      targetBtn.innerText = "Copied!";
      targetBtn.style.color = "var(--neon-orange)";
      
      setTimeout(() => {
        targetBtn.innerText = originalText;
        targetBtn.style.color = "";
      }, 1200);
    }
  }).catch(err => {
    console.error("Vault copy failed: ", err);
  });
}
    function initializeCurrentDate() {
  const dateOptions = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
  const formattedDate = new Date().toLocaleDateString('en-US', dateOptions);
  
  const dateDisplay = document.getElementById('current-date-display');
  if (dateDisplay) {
    dateDisplay.innerText = formattedDate;
  }
}

// Function to copy the date to clipboard upon button click
function copyCurrentDate(btnElement) {
  const dateOptions = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
  const formattedDate = new Date().toLocaleDateString('en-US', dateOptions);
  
  navigator.clipboard.writeText(formattedDate).then(() => {
    const textSpan = btnElement.querySelector('#current-date-display');
    if (textSpan) {
      const originalText = textSpan.innerText;
      textSpan.innerText = "Copied!";
      textSpan.style.color = "var(--neon-orange)";
      
      setTimeout(() => {
        textSpan.innerText = originalText;
        textSpan.style.color = ""; // Revert to default theme color
      }, 1500);
    }
  }).catch(err => {
    console.error("Failed to copy date: ", err);
    alert("Unable to copy date. Check console for details.");
  });
}

// Ensure the date initializes when the application boots up
document.addEventListener('DOMContentLoaded', () => {
  initializeCurrentDate();
});
  </script>
