    function submitCallTrendingLog() {
      const submitBtn = document.getElementById('trend-submit-btn');
      const payload = {
        callType: document.getElementById('trend-call-type').value,
        reason: document.getElementById('trend-reason').value,
        notes: document.getElementById('trend-notes').value.trim()
      };
      
      submitBtn.innerText = "Sending...";
